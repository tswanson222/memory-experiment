trev_knn <- function(x, y, cl, k = 1){
if(is(x, 'data.frame')){
message('Not ready yet')
} else {
euc <- function(X){abs(X[1] - X[2])}
out <- lapply(y, function(z) apply(data.frame(x, z), 1, euc))
picks <- sapply(out, function(z){
z1 <- cl[order(z)[1:k]]
tab <- table(z1)
if(length(tab) == 1){
z2 <- tab
} else if(length(unique(tab)) == 1){
z2 <- tab[sample(1:length(tab), 1)]
} else {
z2 <- which.max(tab)
}
return(names(z2))
})
return(picks)
}
}
